# ET Tracker Environment Variables
# Copy this file to .env and fill in the values for your environment

# App Environment
# Set to 'development', 'staging', or 'production'
# EXPO_PUBLIC_APP_ENV=development

# Google Maps API Key (required for Android maps)
# Get your API key from https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_api_key_here

# Sentry DSN for error tracking (EXPO_PUBLIC_ prefix required for runtime access)
# Get your DSN from https://sentry.io/
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Sentry organization and project (for source maps, no EXPO_PUBLIC_ prefix needed)
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# API Configuration (if using external APIs)
# EXPO_PUBLIC_API_URL=https://api.example.com
