{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "plugins": ["prettier-plugin-sort-imports"],
  "importOrder": ["^react", "^react-native", "^@react", "^@", "^[.]"],
  "importOrderSeparation": true,
  "importOrderCaseInsensitive": true
}
